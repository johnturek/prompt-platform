# Application
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database path (defaults to /data/prompt.db, override for local dev)
DB_PATH=./data/prompt.db

# Session (generate a long random string for production)
SESSION_SECRET=change-me-to-a-long-random-string

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Set to true to return mock prompts without calling Azure (useful for dev/testing)
MOCK_AI=false
